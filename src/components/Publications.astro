---
import { Image } from 'astro:assets';
import publications from '../data/publications.json';

// Import your local badge images
import imgAvailable from '/public/assets/acm_badges/artifacts_available_v1_1.png';
import imgEvaluated from '/public/assets/acm_badges/artifacts_evaluated_reusable_v1_1.png';
import imgReproduced from '/public/assets/acm_badges/results_reproduced_v1_1.png';

// Accept a boolean prop to filter by selected publications
const { filterSelected } = Astro.props;

// Filter the array if the prop is true, otherwise show all
const displayPublications = filterSelected 
  ? publications.filter((pub) => pub.selected) 
  : publications;

// Helper function to bold your name
const formatAuthors = (authors: string) => {
  return authors.replace(
    /(Quentin Guimard\*?)/g, 
    '<span class="font-bold text-zinc-900 dark:text-zinc-100">$1</span>'
  );
};

// Map the JSON strings to the imported Image objects
const badgeImages: Record<string, ImageMetadata> = {
  "Artifacts Available": imgAvailable,
  "Artifacts Evaluated & Reusable": imgEvaluated,
  "Results Reproduced": imgReproduced
};

const HeadingTag = filterSelected ? "h3" : "h2";
---

<div class="space-y-4">
  {displayPublications.map((pub) => (
    <article class="p-5 border border-zinc-200 dark:border-zinc-800 rounded-xl bg-white/50 dark:bg-zinc-900/50 backdrop-blur-sm hover:border-indigo-500/50 dark:hover:border-indigo-500/50 transition-colors shadow-sm group">
      
      <!-- Title -->
      <HeadingTag class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 leading-tight group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
        {pub.title}
      </HeadingTag>
      
      <!-- Authors -->
      <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-2" set:html={formatAuthors(pub.authors)} />
      
      <!-- Metadata Row -->
      <div class="flex flex-wrap items-center gap-3 mt-3 font-mono text-xs text-zinc-600 dark:text-zinc-400">
        <span class="px-2 py-0.5 rounded-md bg-zinc-100 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-800 dark:text-zinc-300">
          {pub.venue}
        </span>
        <span>{pub.year}</span>
        
        <!-- Award Badge -->
        {pub.award && (
          <span class="flex items-center gap-1 px-2 py-0.5 rounded-md bg-amber-100 dark:bg-amber-900/30 border border-amber-300 dark:border-amber-700 text-amber-800 dark:text-amber-400 font-semibold tracking-tight">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
            {pub.award}
          </span>
        )}

        <!-- Official ACM Badges -->
        {pub.badges && pub.badges.map((badge) => (
          <Image 
            src={badgeImages[badge]} 
            alt={badge} 
            title={badge}
            width="40"
            height="40"
            class="h-5 w-auto drop-shadow-sm" 
          />
        ))}
      </div>

      <!-- Action Links -->
      {pub.links && Object.keys(pub.links).length > 0 && (
        <div class="flex flex-wrap gap-3 mt-4">
          {Object.entries(pub.links).map(([label, url]) => (
            <a 
              href={url as string} 
              target="_blank" 
              rel="noopener noreferrer"
              aria-label={`${label} for ${pub.title}`}
              class="font-mono text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 hover:underline underline-offset-4 transition-colors"
            >
              [{label}]
            </a>
          ))}
        </div>
      )}
    </article>
  ))}
</div>
