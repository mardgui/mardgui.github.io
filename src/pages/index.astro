---
// src/pages/index.astro

import '../styles/global.css';

import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Publications from '../components/Publications.astro';
import Projects from '../components/Projects.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Quentin Guimard - Trustworthy AI Researcher</title>
	  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <style is:global>
      /* Inter Variable Font (Weights 100-900 in one file) */
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-display: optional;
        font-weight: 100 900;
        src: url(@fontsource-variable/inter/files/inter-latin-wght-normal.woff2) format('woff2-variations');
      }

      /* JetBrains Mono Variable Font (Weights 100-800 in one file) */
      @font-face {
        font-family: 'JetBrains Mono';
        font-style: normal;
        font-display: optional;
        font-weight: 100 800;
        src: url(@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2) format('woff2-variations');
      }

      body { font-family: 'Inter', sans-serif; }
      .font-mono { font-family: 'JetBrains Mono', monospace; }
    </style>

    <meta name="description" content="Quentin Guimard - Postdoctoral Researcher in Computer Vision and Trustworthy AI at the University of Trento." />
    <meta property="og:title" content="Quentin Guimard | Trustworthy AI Researcher" />
    <meta property="og:description" content="Postdoctoral Researcher focusing on auditing foundation models, mitigating biases, and mechanistic interpretability." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://mardgui.github.io/og-image.jpg" />
    <meta property="twitter:image" content="https://mardgui.github.io/og-image.jpg" />

    <meta name="google-site-verification" content="3u28iz_rRKaY0WZXCaAeskp5zxXfYtMG_GvrpBKl0s4" />
  </head>
  
  <body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 transition-colors duration-300">
    <div class="absolute inset-0 -z-10 h-full w-full bg-zinc-50 dark:bg-zinc-950 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    
	<Header />

    <main class="max-w-3xl mx-auto px-6 py-10">
      <Hero />
      
      <div class="h-px w-full bg-gradient-to-r from-transparent via-zinc-300 dark:via-zinc-700 to-transparent my-12"></div>
      
      <section>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="text-2xl font-semibold tracking-tight">Selected Publications</h2>
          <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-800"></div>
        </div>
        
        <!-- Only show selected publications -->
        <Publications filterSelected={true} />
        
        <!-- Link to the full list -->
        <div class="mt-8 text-center">
          <a href="/publications" class="inline-flex items-center gap-2 font-mono text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            View full publication list <span>&rarr;</span>
          </a>
        </div>
      </section>

	  <div class="h-px w-full bg-gradient-to-r from-transparent via-zinc-300 dark:via-zinc-700 to-transparent my-12"></div>

	  <section>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="text-2xl font-semibold tracking-tight">Open Source & Frameworks</h2>
          <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-800"></div>
        </div>
        
        <Projects filterSelected={true} />
        
        <div class="mt-8 text-center">
          <a href="/projects" class="inline-flex items-center gap-2 font-mono text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            View all projects <span>&rarr;</span>
          </a>
        </div>
      </section>
    </main>

	<Footer />
  </body>
</html>